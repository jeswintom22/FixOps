DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/fixops_iq
DB_ECHO=false
APP_ENV=development
LOG_LEVEL=INFO

AI_PROVIDER=azure_openai
ENDPOINT=https://your-resource.openai.azure.com
API_KEY=replace-me
API_VERSION=2024-02-01
CHAT_MODEL=gpt-4.1-mini
CHAT_DEPLOYMENT=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DEPLOYMENT=text-embedding-3-small

FIXOPS_API_URL=http://127.0.0.1:8000

# Backward-compatible aliases still supported by the backend:
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=

# Legacy prototype settings below are optional and only needed for the older root-level flow.
LLM_PROVIDER=ollama
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OLLAMA_MODEL=qwen3:8b
