# FixOps IQ — Environment Configuration
#
# HYBRID SETUP (recommended for hackathon):
#   LLM calls  → Ollama (local, free)
#   Embeddings → Azure AI Foundry (text-embedding-3-large)
#
# FULL MOCK SETUP (no API keys needed):
#   Set AI_PROVIDER=mock  and comment out everything else

# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/fixops_iq
DB_ECHO=false
APP_ENV=development
LOG_LEVEL=INFO

# ─── LLM provider (chat + reasoning) ────────────────────
# Options: ollama | azure_openai | azure_foundry | mock
LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen3:8b

# ─── Embedding provider (knowledge retrieval via Azure) ──
# Options: azure_openai | azure_foundry | ollama | mock
EMBEDDING_PROVIDER=azure_openai
ENDPOINT=https://your-resource.openai.azure.com
API_KEY=replace-me
API_VERSION=2024-02-01
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ─── Streamlit UI ────────────────────────────────────────
FIXOPS_API_URL=http://127.0.0.1:8000

# ─── Full mock mode (overrides everything above) ─────────
# Uncomment the line below to run with zero API dependencies
# AI_PROVIDER=mock